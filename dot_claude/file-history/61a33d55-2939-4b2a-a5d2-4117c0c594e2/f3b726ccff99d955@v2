async def _extract_talent_bank_results(page: Page) -> List[CandidateBasic]:
    """Extract candidate information from talent bank results page.

    The talent bank UI uses the same enterprise card layout.
    Uses JS-based extraction tailored to the talent bank cards.

    Args:
        page: Playwright page instance on the talent bank results page

    Returns:
        List of CandidateBasic objects
    """
    candidates = []

    try:
        await page.wait_for_load_state("networkidle", timeout=10000)
    except Exception:
        pass

    try:
        candidates_data = await page.evaluate('''() => {
            const candidates = [];
            const seenIds = new Set();

            // Find cards by "立即沟通" button proximity
            const chatBtns = [...document.querySelectorAll('[class*="btn"]')].filter(
                b => b.textContent?.trim() === '立即沟通'
            );
            const foundCards = new Set();
            for (const btn of chatBtns) {
                let card = btn.parentElement;
                for (let i = 0; i < 8 && card; i++) {
                    const rect = card.getBoundingClientRect();
                    if (rect.width > 200 && rect.height > 80) break;
                    card = card.parentElement;
                }
                if (card) foundCards.add(card);
            }
            const cards = Array.from(foundCards);

            for (const card of cards) {
                // Extract structured data using class-based selectors
                // Name: bold span (font-weight-bold color-stress)
                const nameEl = card.querySelector('[class*="font-weight-bold"][class*="color-stress"]');
                const name = nameEl?.textContent?.trim() || '';
                if (!name) continue;

                // Collect all text nodes with parent info
                const nodes = [];
                const walker = document.createTreeWalker(card, NodeFilter.SHOW_TEXT, null, false);
                while (walker.nextNode()) {
                    const text = walker.currentNode.textContent.trim();
                    if (text && text.length > 0 && text.length < 200) {
                        nodes.push({
                            text,
                            cls: walker.currentNode.parentElement?.className || '',
                            tag: walker.currentNode.parentElement?.tagName || '',
                        });
                    }
                }

                // Years of experience: "N年" pattern
                let years = '';
                for (const n of nodes) {
                    if (/^\d+年$/.test(n.text)) { years = n.text; break; }
                }

                // Location: from demographic spans (after years, before 期望)
                let location = '';
                for (const n of nodes) {
                    // Location pattern: Chinese city/district names
                    if (/^[\u4e00-\u9fa5]{2,8}$/.test(n.text) &&
                        !n.cls.includes('font-weight-bold') &&
                        !n.cls.includes('tag___') &&
                        !n.cls.includes('occTag') &&
                        !/^(本科|硕士|博士|大专|MBA|EMBA)$/.test(n.text) &&
                        !/^(在线|离线|急求职|今日活跃|立即沟通|不合适|发送后继续沟通)$/.test(n.text)) {
                        // Check if this looks like a location (has district suffix or province+city)
                        if (/[区市省县]$/.test(n.text) || /^(北京|上海|广东|浙江|江苏|四川|湖北|安徽|福建|天津|重庆)/.test(n.text)) {
                            location = n.text;
                            break;
                        }
                    }
                }

                // Company & title: from work experience section
                // Pattern: date_start + date_end + company + · + title
                let company = '';
                let title = '';
                const datePattern = /^\d{4}\.\d{1,2}$/;
                for (let i = 0; i < nodes.length; i++) {
                    if (datePattern.test(nodes[i].text) && nodes[i].cls.includes('min-w-')) {
                        // Found a date range start, skip date nodes
                        let j = i + 1;
                        // Skip "- 至今" or "- 2024.06"
                        while (j < nodes.length && (nodes[j].text === '-' || nodes[j].text.startsWith('- ') || datePattern.test(nodes[j].text))) {
                            j++;
                        }
                        // Next non-separator text is company
                        if (j < nodes.length && nodes[j].text !== '·') {
                            company = nodes[j].text;
                            // Look for title after separator
                            for (let k = j + 1; k < nodes.length && k <= j + 5; k++) {
                                if (nodes[k].text === '·') continue;
                                if (/^\d{4}\.\d{1,2}$/.test(nodes[k].text)) break;
                                // Collect title parts (may be split by search highlights)
                                const titleParts = [];
                                for (let m = k; m < nodes.length && m <= k + 4; m++) {
                                    if (nodes[m].text === '·' || /^\d{4}\.\d{1,2}$/.test(nodes[m].text)) break;
                                    if (/至今/.test(nodes[m].text) || nodes[m].cls.includes('min-w-')) break;
                                    if (nodes[m].tag === 'MARK' || nodes[m].tag === 'SPAN') {
                                        titleParts.push(nodes[m].text);
                                    } else break;
                                }
                                title = titleParts.join('');
                                if (title.length > 30) title = title.substring(0, 30);
                                break;
                            }
                            break;  // Use first (most recent) work experience
                        }
                    }
                }

                // ID generation
                const idSource = (name || '') + '|' + (company || '') + '|' + (title || '');
                let hash = 0;
                for (let j = 0; j < idSource.length; j++) {
                    const ch = idSource.charCodeAt(j);
                    hash = ((hash << 5) - hash) + ch;
                    hash = hash & hash;
                }
                const maimaiId = 'mm_' + Math.abs(hash).toString(16).padStart(8, '0');
                if (seenIds.has(maimaiId)) continue;
                seenIds.add(maimaiId);

                // Profile URL
                let profileUrl = '';
                const links = card.querySelectorAll('a[href]');
                for (const link of links) {
                    const href = link.getAttribute('href') || '';
                    if (href.includes('/profile/detail') || href.includes('/contact/detail/') || href.includes('dstu=') || href.includes('egid=')) {
                        profileUrl = href.startsWith('http') ? href : 'https://maimai.cn' + href;
                        break;
                    }
                }

                candidates.push({
                    name, title: title || '', company: company || '',
                    maimai_id: maimaiId, profile_url: profileUrl,
                    location: location || '', years: years || '',
                });
            }

            return candidates;
        }''')

        logger.info(f"Talent bank extraction found {len(candidates_data)} candidates")

        for data in candidates_data:
            if data.get("name"):
                candidates.append(CandidateBasic(
                    maimai_id=data.get("maimai_id", ""),
                    name=data.get("name", ""),
                    title=data.get("title", ""),
                    company=data.get("company", ""),
                    location=data.get("location", ""),
                    profile_url=data.get("profile_url", ""),
                ))

        candidates = [c for c in candidates if c.name not in PREMIUM_PLACEHOLDER_NAMES]
        logger.info(f"Talent bank: extracted {len(candidates)} candidates from page")

    except Exception as e:
        logger.error(f"Error extracting talent bank results: {e}")

    return candidates


# ---------------------------------------------------------------------------
# Recruit Manage path (Path D) — for standard paid accounts
# ---------------------------------------------------------------------------

RECRUIT_MANAGE_URL_MARKER = "search_v2"

# Year range tags the UI offers
_YEAR_RANGES = [
    (1, "1-3年"),
    (3, "3-5年"),
    (5, "5-10年"),
    (10, "10年以上"),
]


async def search_candidates_recruit_manage(
    keywords: str,
    company: Optional[tuple] = None,
    pages: int = 1,
    browser: Optional[BrowserManager] = None,
    min_years: Optional[int] = None,
    max_years: Optional[int] = None,
) -> List[CandidateBasic]:
    """Search for candidates via the recruit_manage path (Path D).

    For standard paid accounts without enterprise/talent_bank access.
    Navigates same-tab: homepage → #recruiter_manage → search_v2 page.
    Uses structured filters (keyword, position, city, years, company preset tags).
    Candidate card layout matches enterprise, so reuses _extract_enterprise_results().

    Args:
        keywords: Search keywords
        company: Preset company tag names to click (e.g. ("TMDJ", "阿里"))
        pages: Number of scroll-pages to extract
        browser: Browser manager instance
        min_years: Minimum work years filter (multi-selects all ranges >= min_years)
        max_years: Maximum work years threshold (excludes ranges with threshold > max_years)

    Returns:
        List of CandidateBasic objects
    """
    validate_keywords(keywords)

    if browser is None:
        browser = get_browser_manager()

    config = get_config()
    rate_limiter = get_rate_limiter()
    db_manager = get_db_manager()

    await ensure_logged_in(browser)

    all_candidates: List[CandidateBasic] = []
    seen_ids: set = set()

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console,
    ) as progress:
        task = progress.add_task("Opening recruit manage...", total=None)

        try:
            await async_check_rate_limit("search")

            page = browser.page

            # Step 1: Navigate to homepage, click 招聘管理 link
            progress.update(task, description="Navigating to recruit manage...")
            await retry_navigation(page, MAIMAI_HOME_URL, wait_until="domcontentloaded")
            await async_random_delay("page_load")

            entry_sel = config.get_selector("recruit_manage.entry_link")
            entry_link = await page.wait_for_selector(entry_sel, timeout=8000)
            if not entry_link:
                raise SelectorNotFoundError(f"Could not find recruit manage entry: {entry_sel}")
            await entry_link.click()
            await async_random_delay("page_load")

            # Wait for search_v2 URL
            try:
                await page.wait_for_url(
                    lambda url: RECRUIT_MANAGE_URL_MARKER in url,
                    timeout=15000,
                )
            except Exception:
                logger.warning(f"search_v2 URL not matched, current: {page.url}")

            await async_random_delay("action")

            # Step 2: Add keyword filter
            progress.update(task, description=f"Adding keyword: {keywords}")

            add_kw_sel = config.get_selector("recruit_manage.add_keyword_button")
            add_kw_btn = await page.wait_for_selector(add_kw_sel, timeout=5000)
            if add_kw_btn:
                await add_kw_btn.click()
                await async_random_delay("action")

            kw_input_sel = config.get_selector("recruit_manage.keyword_input")
            await page.wait_for_selector(kw_input_sel, timeout=5000)
            await human_type(page, kw_input_sel, keywords)
            await async_random_delay("action")

            kw_submit_sel = config.get_selector("recruit_manage.keyword_submit")
            submit_btn = await page.wait_for_selector(kw_submit_sel, timeout=3000)
            if submit_btn:
                await submit_btn.click()
                await async_random_delay("page_load")

            # Step 3: Set year filter if requested (multi-select ranges >= min_years)
            if min_years:
                progress.update(task, description=f"Setting year filter: {min_years}+...")
                try:
                    add_years_sel = config.get_selector("recruit_manage.add_years_button")
                    years_btn = await page.wait_for_selector(add_years_sel, timeout=5000)
                    if years_btn:
                        await years_btn.click()
                        await async_random_delay("action")

                        # Select year ranges >= min_years and <= max_years
                        applicable = [
                            (threshold, label) for threshold, label in _YEAR_RANGES
                            if threshold >= min_years and (max_years is None or threshold <= max_years)
                        ]
                        if not applicable:
                            applicable = [_YEAR_RANGES[-1]]  # fallback to 10年以上

                        add_cond_sel = config.get_selector("recruit_manage.add_condition_button")
                        for i, (_, label) in enumerate(applicable):
                            if i > 0:
                                # Click the LAST "+" button (the one for years section,
                                # not keyword or other sections above it)
                                try:
                                    await page.wait_for_timeout(1000)
                                    add_btn = page.locator(add_cond_sel).last
                                    await add_btn.wait_for(state="visible", timeout=5000)
                                    await add_btn.click()
                                    await page.wait_for_timeout(1500)  # wait for dropdown to reopen
                                except Exception:
                                    logger.debug(f"Could not click add condition button for year: {label}")

                            opt = await page.wait_for_selector(f"text='{label}'", timeout=5000)
                            if opt:
                                await opt.click()
                                await page.wait_for_timeout(800)  # wait for tag to settle
                                logger.info(f"Selected year filter: {label}")
                except Exception as e:
                    logger.warning(f"Failed to set year filter: {e}")

            # Step 4: Set company filter if specified (preset tags)
            if company:
                progress.update(task, description="Adding company filter...")
                try:
                    add_co_sel = config.get_selector("recruit_manage.add_company_button")
                    add_co_btn = await page.wait_for_selector(add_co_sel, timeout=5000)
                    if add_co_btn:
                        await add_co_btn.click()
                        await async_random_delay("action")

                    add_cond_sel = config.get_selector("recruit_manage.add_condition_button")
                    for i, co_name in enumerate(company):
                        if i > 0:
                            # Click the LAST "+" button (the one for company section)
                            try:
                                await page.wait_for_timeout(1000)
                                add_btn = page.locator(add_cond_sel).last
                                await add_btn.wait_for(state="visible", timeout=5000)
                                await add_btn.click()
                                await page.wait_for_timeout(1500)  # wait for dropdown to reopen
                            except Exception:
                                logger.debug(f"Could not click add condition button for company: {co_name}")

                        opt = await page.wait_for_selector(f"text='{co_name}'", timeout=5000)
                        if opt:
                            await opt.click()
                            await page.wait_for_timeout(800)  # wait for tag to settle
                            logger.info(f"Selected company filter: {co_name}")
                except Exception as e:
                    logger.warning(f"Failed to set company filter: {e}")

            # Wait for results to load
            await page.wait_for_timeout(3000)
            await check_captcha(page, report_to_rate_limiter=True)

            # Step 5: Extract candidates (with pagination via scroll)
            for page_num in range(1, pages + 1):
                progress.update(task, description=f"Extracting page {page_num}/{pages}...")

                # Reuse enterprise extraction — same card layout
                candidates = await _extract_enterprise_results(page)

                # Deduplicate across scroll pages
                candidates = [c for c in candidates if c.maimai_id not in seen_ids]
                for c in candidates:
                    seen_ids.add(c.maimai_id)

                if not candidates:
                    logger.info(f"No recruit_manage results on page {page_num}")
                    break

                # Filter non-R&D roles
                before_filter = len(candidates)
                candidates = [c for c in candidates if not _is_non_rd_title(c.title)]
                filtered = before_filter - len(candidates)
                if filtered > 0:
                    logger.info(f"Filtered out {filtered} non-R&D candidates")

                all_candidates.extend(candidates)
                progress.update(task, description=f"Page {page_num}: Found {len(candidates)} candidates")

                rate_limiter.log_action("search", {
                    "keywords": keywords,
                    "page": page_num,
                    "results": len(candidates),
                    "mode": "recruit_manage",
                })

                try:
                    _save_candidates_to_db(db_manager, candidates, keywords)
                except Exception as e:
                    console.print(f"[yellow]Warning: Failed to save candidates to DB: {e}[/yellow]")

                # Scroll for next page (infinite scroll)
                if page_num < pages:
                    await human_scroll(page, "down", distance=800)
                    await async_random_delay("page_load")
                    await page.wait_for_timeout(2000)

        except Exception as e:
            logger.error(f"Recruit manage search error: {e}")
            await browser.screenshot("recruit_manage_search_error")
            progress.update(task, description=f"Error: {str(e)[:40]}")

    _log_search_history(db_manager, keywords, company, None, pages, len(all_candidates))

    console.print(f"[green]Recruit manage search complete. Found {len(all_candidates)} candidates.[/green]")
    return all_candidates
