[tool.poetry]
name = "maimai-assistant"
version = "0.1.0"
description = "Semi-automated recruitment assistant for Maimai platform"
authors = ["Your Name <your.email@example.com>"]
readme = "README.md"
license = "MIT"

[tool.poetry.dependencies]
python = "^3.10"
patchright = "^1.5.0"
click = "^8.1.7"
rich = "^13.7.0"
questionary = "^2.0.1"
pandas = "^2.2.0"
openpyxl = "^3.1.2"
sqlalchemy = "^2.0.25"
loguru = "^0.7.2"
pydantic = "^2.5.3"
tenacity = "^8.2.3"
python-dotenv = "^1.0.0"
faker = "^22.0.0"
httpx = "^0.26.0"
emunium = "^0.3.0"
cryptography = ">=41.0.0"
opencv-python-headless = "^4.9.0"

[tool.poetry.dev-dependencies]
pytest = "^7.4.3"
pytest-asyncio = "^0.21.1"
black = "^23.12.1"
ruff = "^0.1.9"
mypy = "^1.8.0"

[tool.poetry.scripts]
maimai = "src.cli.main:cli"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"

[tool.black]
line-length = 100
target-version = ['py310']

[tool.ruff]
line-length = 100
target-version = "py310"

[tool.mypy]
python_version = "3.10"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
