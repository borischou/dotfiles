#!/usr/bin/env python
"""Database backup script."""

import sys
import shutil
from pathlib import Path
from datetime import datetime, timedelta

# Add src to path
sys.path.insert(0, str(Path(__file__).parent.parent))

from src.utils.config import get_config
from src.utils.logger import setup_logger
from loguru import logger


def backup_database(silent: bool = False) -> tuple[bool, str]:
    """
    Backup database to timestamped file.

    保留最近 7 天的备份，自动清理旧备份。

    Args:
        silent: If True, suppress console output (use logger only)

    Returns:
        Tuple of (success: bool, backup_path: str)
    """
    try:
        # Get configuration
        config = get_config()
        db_path = Path(config.get('data.database_path', 'data/maimai.db'))

        if not db_path.exists():
            logger.error(f"Database file not found: {db_path}")
            return False, ""

        # Create backup filename with timestamp
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        backup_dir = db_path.parent / 'backups'
        backup_dir.mkdir(parents=True, exist_ok=True)

        backup_path = backup_dir / f'maimai_{timestamp}.db'

        # Copy database file
        shutil.copy2(db_path, backup_path)

        # Verify backup
        if not backup_path.exists() or backup_path.stat().st_size == 0:
            logger.error("Backup file is empty or not created")
            return False, ""

        # Get file sizes
        original_size = db_path.stat().st_size
        backup_size = backup_path.stat().st_size

        if not silent:
            logger.info(f"数据库已备份: {backup_path.name} ({backup_size:,} bytes)")

        # Clean up old backups (keep last 7 days)
        cutoff_date = datetime.now() - timedelta(days=7)
        removed_count = 0

        for old_backup in backup_dir.glob('maimai_*.db'):
            # Get file modification time
            mtime = datetime.fromtimestamp(old_backup.stat().st_mtime)
            if mtime < cutoff_date:
                try:
                    old_backup.unlink()
                    removed_count += 1
                    if not silent:
                        logger.debug(f"删除旧备份: {old_backup.name}")
                except Exception as e:
                    logger.warning(f"Failed to delete old backup {old_backup.name}: {e}")

        if removed_count > 0 and not silent:
            logger.info(f"清理了 {removed_count} 个旧备份（7天前）")

        return True, str(backup_path)

    except Exception as e:
        logger.error(f"Backup failed: {e}")
        return False, ""


def main():
    """CLI entry point for manual backup."""
    try:
        # Setup logger
        setup_logger()

        logger.info("Starting database backup...")

        success, backup_path = backup_database(silent=False)

        if success:
            logger.success("✓ 备份完成！")
            return 0
        else:
            logger.error("✗ 备份失败")
            return 1

    except Exception as e:
        logger.error(f"Backup failed: {e}")
        return 1


if __name__ == '__main__':
    sys.exit(main())
