{
  "browser": {
    "cdp_endpoint": "http://127.0.0.1:9222",
    "timeout": 30000
  },
  "rate_limits": {
    "search_per_hour": 20,
    "search_per_day": 100,
    "profile_view_per_hour": 30,
    "profile_view_per_day": 150,
    "message_per_hour": 30,
    "message_per_day": 100,
    "min_interval_seconds": 10
  },
  "delays": {
    "page_load_min": 1.5,
    "page_load_max": 3,
    "action_min": 0.3,
    "action_max": 1.0,
    "typing_min": 0.05,
    "typing_max": 0.15,
    "scroll_min": 0.5,
    "scroll_max": 1.5
  },
  "data": {
    "database_path": "data/maimai.db",
    "session_path": "data/.session/maimai_session.json",
    "export_dir": "data/exports",
    "log_dir": "data/logs",
    "screenshot_dir": "data/screenshots"
  },
  "logging": {
    "level": "INFO",
    "rotation": "10 MB",
    "retention": "30 days",
    "format": "<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>"
  }
}
