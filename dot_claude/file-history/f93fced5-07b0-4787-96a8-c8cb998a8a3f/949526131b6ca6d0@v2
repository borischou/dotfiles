<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Maimai Assistant{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
    <nav class="container-fluid">
        <ul>
            <li><strong>Maimai Assistant</strong></li>
        </ul>
        <ul>
            <li><a href="/" {% if request.url.path == '/' %}aria-current="page"{% endif %}>Pipeline</a></li>
            <li><a href="/data" {% if request.url.path == '/data' %}aria-current="page"{% endif %}>Data</a></li>
        </ul>
        <ul>
            <li><span id="connection-badge" class="badge" data-status="unknown">--</span></li>
        </ul>
    </nav>

    <main class="container">
        {% block content %}{% endblock %}
    </main>

    <footer class="container">
        <small>Maimai Assistant v1.0 &mdash; <span id="ws-status">WebSocket: connecting...</span></small>
    </footer>

    <script src="/static/js/ws.js"></script>
    <script src="/static/js/app.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
