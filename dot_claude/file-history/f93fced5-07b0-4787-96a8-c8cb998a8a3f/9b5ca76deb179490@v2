"""Take screenshots of the new 2-page Web UI."""
from playwright.sync_api import sync_playwright

with sync_playwright() as p:
    browser = p.chromium.launch(headless=True)
    page = browser.new_page(viewport={"width": 1280, "height": 900})

    # Page 1: Main page (Pipeline)
    page.goto("http://localhost:8000/")
    page.wait_for_load_state("networkidle")
    page.wait_for_timeout(1000)
    page.screenshot(path="/tmp/page_main.png", full_page=True)
    print("Screenshot: /tmp/page_main.png")

    # Page 2: Data page
    page.goto("http://localhost:8000/data")
    page.wait_for_load_state("networkidle")
    page.wait_for_timeout(1000)
    page.screenshot(path="/tmp/page_data.png", full_page=True)
    print("Screenshot: /tmp/page_data.png")

    # Test redirect: /pipeline -> /
    resp = page.goto("http://localhost:8000/pipeline")
    print(f"Redirect /pipeline -> {page.url} (status chain included 301: {resp.url})")

    # Test redirect: /candidates -> /data
    resp = page.goto("http://localhost:8000/candidates")
    print(f"Redirect /candidates -> {page.url}")

    browser.close()
    print("Done!")
