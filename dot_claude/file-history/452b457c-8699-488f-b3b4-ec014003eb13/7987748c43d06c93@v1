"""Settings routes — view and edit configuration."""

import json
from pathlib import Path

from fastapi import APIRouter, Request, Form
from fastapi.responses import HTMLResponse, RedirectResponse

from src.web.app import templates
from src.utils.config import get_config

router = APIRouter()


@router.get("/", response_class=HTMLResponse)
async def settings_page(request: Request):
    """Render settings page with current configuration."""
    config = get_config()

    return templates.TemplateResponse("settings.html", {
        "request": request,
        "settings": config._settings,
        "settings_json": json.dumps(config._settings, ensure_ascii=False, indent=2),
    })


@router.post("/")
async def save_settings(request: Request, settings_json: str = Form(...)):
    """Save settings to disk."""
    config = get_config()

    try:
        new_settings = json.loads(settings_json)
    except json.JSONDecodeError as e:
        return HTMLResponse(
            f'<p><mark>JSON 格式错误: {e}</mark></p>',
            status_code=400,
        )

    # Update in-memory
    config._settings = new_settings

    # Persist to disk
    settings_path = Path(config.config_dir) / "settings.json"
    with open(settings_path, 'w', encoding='utf-8') as f:
        json.dump(new_settings, f, ensure_ascii=False, indent=2)
        f.write('\n')

    return RedirectResponse(url="/settings", status_code=303)
