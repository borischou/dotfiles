"""Pipeline routes — control panel, start/cancel, SSE progress."""

import json
from datetime import datetime, timezone

from fastapi import APIRouter, Request, Form
from fastapi.responses import HTMLResponse
from sse_starlette.sse import EventSourceResponse
from pydantic import ValidationError

from src.web.app import task_queue, templates
from src.web.task_queue import BrowserTask, TaskPriority
from src.web.schemas import PipelineParams
from src.core.browser import get_browser_manager
from src.modules.auth import ensure_logged_in
from src.services.pipeline import run_pipeline
from src.models.database import PipelineRun, get_db_manager

router = APIRouter()


@router.get("/", response_class=HTMLResponse)
async def pipeline_page(request: Request):
    """Pipeline control panel."""
    db = get_db_manager()

    with db.session_scope() as session:
        recent_runs = session.query(PipelineRun).order_by(
            PipelineRun.started_at.desc()
        ).limit(10).all()

        runs = []
        for r in recent_runs:
            runs.append({
                "task_id": r.task_id,
                "status": r.status,
                "keywords": r.keywords,
                "template_name": r.template_name,
                "started_at": r.started_at,
                "finished_at": r.finished_at,
                "result": r.result,
            })

    return templates.TemplateResponse("pipeline.html", {
        "request": request,
        "pipeline_busy": task_queue.is_busy,
        "current_task_id": task_queue.current_task_id,
        "queue_size": task_queue.queue_size,
        "recent_runs": runs,
    })


@router.post("/start", response_class=HTMLResponse)
async def start_pipeline(
    request: Request,
    keywords: str = Form(...),
    template_name: str = Form(...),
    location: str = Form(""),
    pages: int = Form(3),
    batch_pages: int = Form(0),
    experience: str = Form(""),
    education: str = Form(""),
    salary: str = Form(""),
    skip_messaged: bool = Form(True),
    dry_run: bool = Form(False),
):
    """Start a pipeline task (queued if another is running)."""
    try:
        params = PipelineParams(
            keywords=keywords,
            template_name=template_name,
            location=location,
            pages=pages,
            batch_pages=batch_pages,
            experience=experience,
            education=education,
            salary=salary,
            skip_messaged=skip_messaged,
            dry_run=dry_run,
        )
    except ValidationError as e:
        msg = e.errors()[0]['msg'] if e.errors() else str(e)
        return HTMLResponse(f'<p><mark>{msg}</mark></p>', status_code=400)

    import uuid
    task_id = str(uuid.uuid4())[:8]

    async def _run():
        db = get_db_manager()

        # Record pipeline run
        with db.session_scope() as session:
            run = PipelineRun(
                task_id=task_id,
                status='running',
                keywords=params.keywords,
                template_name=params.template_name,
                params=params.model_dump(exclude={'keywords', 'template_name'}),
            )
            session.add(run)

        try:
            browser = get_browser_manager()
            await ensure_logged_in(browser)

            result = await run_pipeline(
                keywords=tuple(params.keywords),
                template_name=params.template_name,
                variables={},
                location=params.location,
                max_pages=params.pages,
                batch_pages=params.batch_pages,
                experience=params.experience,
                education=params.education,
                salary=params.salary,
                interactive=False,
                skip_messaged=params.skip_messaged,
                dry_run=params.dry_run,
                browser=browser,
            )

            with db.session_scope() as session:
                run_record = session.query(PipelineRun).filter_by(task_id=task_id).first()
                if run_record:
                    run_record.status = 'completed'
                    run_record.result = result
                    run_record.finished_at = datetime.now(timezone.utc)

            return result

        except Exception as e:
            with db.session_scope() as session:
                run_record = session.query(PipelineRun).filter_by(task_id=task_id).first()
                if run_record:
                    run_record.status = 'failed'
                    run_record.result = {"error": str(e)}
                    run_record.finished_at = datetime.now(timezone.utc)
            raise

    task = BrowserTask(
        name=f"pipeline:{','.join(params.keywords)}",
        coroutine_factory=_run,
        priority=TaskPriority.LOW,
        task_id=task_id,
    )
    await task_queue.submit(task)

    queued = task_queue.queue_size > 0 and task_queue.is_busy
    return templates.TemplateResponse("partials/pipeline_progress.html", {
        "request": request,
        "task_id": task.task_id,
        "queued": queued,
    })


@router.delete("/cancel")
async def cancel_pipeline(request: Request):
    """Cancel the running pipeline."""
    cancelled = await task_queue.cancel_current()
    if cancelled:
        return {"status": "ok", "message": "Pipeline cancel requested"}
    return {"status": "noop", "message": "No pipeline running"}


@router.get("/progress/{task_id}")
async def pipeline_progress_sse(request: Request, task_id: str):
    """SSE endpoint for pipeline progress events."""

    async def event_generator():
        async for msg in task_queue.subscribe_progress(task_id):
            if await request.is_disconnected():
                break
            yield {
                "event": msg["event"],
                "data": json.dumps(msg["data"], ensure_ascii=False),
            }

    return EventSourceResponse(event_generator())


@router.get("/queue")
async def queue_status():
    """Get current queue status."""
    return task_queue.get_queue_status()
