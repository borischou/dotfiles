# Maimai chat URL - navigate directly to chat page
MAIMAI_CHAT_URL = "https://maimai.cn/bizmember/uh_chat_pc?u2={user_id}&from=pc_web_search&fr=profile"


def _extract_user_id(profile_url: str) -> Optional[str]:
    """Extract dstu/user_id from a Maimai profile URL for direct chat navigation.

    Only returns IDs that are known to work with the chat URL (u2= parameter).
    Query-param IDs (dstu, u2, egid) are reliable for chat navigation.
    Path-based IDs (/contact/detail/xxx) are NOT the same as chat user IDs
    and should not be used for direct chat URL construction.
    """
    from urllib.parse import urlparse, parse_qs
    parsed = urlparse(profile_url)
    params = parse_qs(parsed.query)
    # Only use query parameter IDs — these are confirmed to work with uh_chat_pc
    for key in ('dstu', 'u2', 'egid'):
        if key in params:
            return params[key][0]
    return None


async def _navigate_to_chat(
    page: Page,
    profile_url: Optional[str],
    config,
    browser: BrowserManager,
    maimai_id: str,
    interactive: bool = False,
    discovered_selectors=None,
) -> bool:
    """Navigate to the chat page for a candidate.

    Tries in order:
    1. Extract user_id from profile_url query params → direct chat URL
    2. Navigate to profile_url, extract user_id from redirected URL → direct chat URL
    3. Click chat button on profile page as fallback

    If no profile_url is provided, looks up the candidate's profile_url from DB.

    Args:
        page: Playwright page instance
        profile_url: Candidate's profile URL (may be None)
        config: Config instance
        browser: Browser manager instance
        maimai_id: Candidate's Maimai ID
        interactive: Enable interactive selector discovery
        discovered_selectors: Shared DiscoveredSelectors instance

    Returns:
        True if successfully navigated to chat page
    """
    db_manager = get_db_manager()

    # Resolve profile URL from DB if not provided
    if not profile_url:
        with db_manager.session_scope() as session:
            db_candidate = session.query(Candidate).filter_by(maimai_id=maimai_id).first()
            profile_url = db_candidate.profile_url if db_candidate else None

        if not profile_url:
            raise PermanentFailureError(f"No profile URL for {maimai_id}")

    # Try extracting user_id directly from profile URL
    user_id = _extract_user_id(profile_url)
    logger.debug(f"_navigate_to_chat: profile_url={profile_url!r}, extracted user_id={user_id}")

    if user_id:
        chat_url = MAIMAI_CHAT_URL.format(user_id=user_id)
        await retry_navigation(page, chat_url, wait_until='domcontentloaded')
        await async_random_delay('page_load')
        return True

    # Navigate to profile page, then try to extract user_id from resulting URL
    logger.debug(f"_navigate_to_chat: navigating to profile {profile_url}")
    await retry_navigation(page, profile_url, wait_until='domcontentloaded')
    await async_random_delay('page_load')

    current_url = page.url
    logger.debug(f"_navigate_to_chat: landed on {current_url}")
    redirected_user_id = _extract_user_id(current_url)
    if redirected_user_id:
        logger.info(f"Extracted user_id={redirected_user_id} from page URL, redirecting to chat")
        chat_url = MAIMAI_CHAT_URL.format(user_id=redirected_user_id)
        await retry_navigation(page, chat_url, wait_until='domcontentloaded')
        await async_random_delay('page_load')
        return True

    # Fallback: click chat button on profile page
    chat_button_found = await _click_chat_button(page, config)
    if chat_button_found:
        await async_random_delay('action')
        return True

    # If interactive mode, trigger selector discovery
    if interactive and discovered_selectors is not None and not discovered_selectors.is_populated:
        from src.modules.selector_discovery import discover_chat_page
        console.print("[yellow]Chat button not found. Entering interactive discovery mode...[/yellow]")
        result = await discover_chat_page(page, maimai_id, browser)
        if result.is_populated:
            discovered_selectors.chat_button = result.chat_button
            discovered_selectors.message_input = result.message_input
            discovered_selectors.send_button = result.send_button
            discovered_selectors.chat_url_pattern = result.chat_url_pattern
            discovered_selectors.skip_chat_button = result.skip_chat_button
            discovered_selectors.is_populated = True
            return True

    console.print("[red]Could not find chat button[/red]")
    await browser.screenshot(f"message_error_{maimai_id}")
    return False


async def extract_contact_quota(page: Page) -> Optional[dict]:
    """Extract contact quota from Quick Contact page's embedded share_data.

    The Quick Contact page server-renders ``window.share_data`` which includes
    ``mem_status.mem_info`` with remaining quotas for various member actions.

    Args:
        page: Playwright page on a Quick Contact (极速联系) page

    Returns:
        Dict with quota info, or None if data is unavailable::

            {
                'uh_left': int,        # 极速联系 remaining
                'addfr_left': int,     # 加好友 remaining
                'dc_left': int,        # 直聊 remaining
                'expire_time': str,    # membership expiry
                'cost': int,           # vouchers consumed per contact
            }
    """
    try:
        quota = await page.evaluate('''() => {
            if (window.share_data && window.share_data.mem_status &&
                window.share_data.mem_status.mem_info) {
                const info = window.share_data.mem_status.mem_info;
                return {
                    uh_left: info.uh_left,
                    addfr_left: info.addfr_left,
                    dc_left: info.dc_left,
                    expire_time: info.expire_time || null,
                    cost: (window.share_data.fast_contact_pay_num || {}).final_num || 1,
                };
            }
            return null;
        }''')
        return quota
    except Exception as e:
        logger.debug(f"Failed to extract contact quota: {e}")
        return None


async def fetch_contact_quota(browser: Optional['BrowserManager'] = None) -> Optional[dict]:
    """Fetch current contact quota by navigating to a Quick Contact page.

    Uses a well-known user ID to load the Quick Contact page and extract
    ``window.share_data.mem_status.mem_info``. Useful for the ``status``
    command or any context where quota needs to be checked independently.

    Args:
        browser: BrowserManager instance (uses global singleton if None)

    Returns:
        Quota dict (see extract_contact_quota), or None on failure
    """
    if browser is None:
        browser = get_browser_manager()

    page = browser.page
    # Use own user ID (u1 == u2 loads the page without actually creating a chat)
    probe_url = MAIMAI_CHAT_URL.format(user_id="1")
    try:
        await retry_navigation(page, probe_url, wait_until='domcontentloaded')
        await asyncio.sleep(2)
        return await extract_contact_quota(page)
    except Exception as e:
        logger.debug(f"Failed to fetch contact quota: {e}")
        return None


def _display_quota(quota: dict, just_sent: bool = True) -> None:
    """Display contact quota info to the console.

    Args:
        quota: Quota dict from extract_contact_quota()
        just_sent: If True, subtract cost from uh_left for post-send display
    """
    uh_left = quota.get('uh_left', 0)
    cost = quota.get('cost', 1)
    if just_sent:
        uh_left = max(0, uh_left - cost)
    console.print(f"[dim]联系券剩余: {uh_left}[/dim]")


async def _handle_quick_contact(page: Page, content: str) -> Optional[bool]:
    """Handle Maimai's "极速联系" (Quick Contact) page.

    This page appears instead of regular chat for some candidates. It has a
    category selector, a textarea, and a "提交" (Submit) button.

    Submission works by manipulating the React component directly: setting
    the message via setState and calling the debounced send method (with
    flush) to trigger the POST to /bizmember/uh-chat/api/send_v2.

    DOM-level textarea.fill() does NOT update React's controlled state, and
    DOM click on the submit button does NOT reliably trigger the send API.

    Args:
        page: Playwright page instance
        content: Message content to send

    Returns:
        True if message was sent via quick contact form,
        False if quick contact page was detected but sending failed,
        None if this is not a quick contact page (caller should continue normal flow)
    """
    try:
        # Detect quick contact page via page title or page content
        is_quick_contact = await page.evaluate('''() => {
            const title = document.title || '';
            const bodyText = document.body ? document.body.innerText : '';
            return title.includes('极速联系') || bodyText.includes('极速联系');
        }''')

        if not is_quick_contact:
            return None

        logger.info("Detected '极速联系' (Quick Contact) page")

        # Validate message length (Quick Contact enforces 10-300 chars)
        if len(content) < 10:
            logger.error(
                f"Quick contact: message too short ({len(content)} chars, "
                "minimum 10). Quick Contact requires 10-300 characters."
            )
            return False
        if len(content) > 300:
            logger.error(
                f"Quick contact: message too long ({len(content)} chars, "
                "maximum 300). Quick Contact requires 10-300 characters."
            )
            return False

        # Extract quota info before submitting (share_data is available on page load)
        quota = await extract_contact_quota(page)

        # Check if quota is exhausted
        if quota and quota.get('uh_left', 0) <= 0:
            raise QuotaExhaustedError(remaining=quota.get('uh_left', 0))

        # Install XHR interceptor to capture the send_v2 response
        await page.evaluate('''() => {
            window.__sendV2Result = null;
            const origOpen = XMLHttpRequest.prototype.open;
            const origSend = XMLHttpRequest.prototype.send;
            XMLHttpRequest.prototype.open = function(m, u) {
                this.__url = u; this.__method = m;
                return origOpen.apply(this, arguments);
            };
            XMLHttpRequest.prototype.send = function(b) {
                if (this.__url && this.__url.includes('send_v2')) {
                    const xhr = this;
                    xhr.addEventListener('load', function() {
                        try {
                            window.__sendV2Result = {
                                status: xhr.status,
                                response: xhr.responseText,
                            };
                        } catch(e) {
                            window.__sendV2Result = {status: xhr.status, error: e.message};
                        }
                    });
                    xhr.addEventListener('error', function() {
                        window.__sendV2Result = {status: 0, error: 'network_error'};
                    });
                }
                return origSend.apply(this, arguments);
            };
        }''')

        # Submit via React component internals:
        # 1. Find the class component that owns the form state
        # 2. Set message + unlock push_type via setState
        # 3. Call the debounced send() method and flush() to execute immediately
        send_triggered = await page.evaluate('''(msg) => {
            const textarea = document.querySelector('textarea');
            if (!textarea) return {success: false, error: 'no textarea'};
            const keys = Object.keys(textarea);
            const fiberKey = keys.find(
                k => k.startsWith('__reactInternalInstance') || k.startsWith('__reactFiber')
            );
            if (!fiberKey) return {success: false, error: 'no React fiber'};

            let fiber = textarea[fiberKey];
            while (fiber) {
                if (fiber.stateNode && fiber.stateNode.state
                    && 'message' in fiber.stateNode.state
                    && typeof fiber.stateNode.send === 'function') {
                    const component = fiber.stateNode;
                    // Set message and ensure push_type is not locked (true = sending lock)
                    component.setState({message: msg, push_type: false}, () => {
                        component.send();
                        if (typeof component.send.flush === 'function') {
                            component.send.flush();
                        }
                    });
                    return {success: true};
                }
                fiber = fiber.return;
            }
            return {success: false, error: 'React component not found'};
        }''', content)

        if not send_triggered.get('success'):
            logger.warning(
                f"Quick contact: failed to trigger send via React: "
                f"{send_triggered.get('error', 'unknown')}"
            )
            return False

        # Wait for the API response (send_v2 XHR)
        send_result = None
        for _ in range(10):
            await asyncio.sleep(0.5)
            send_result = await page.evaluate('() => window.__sendV2Result')
            if send_result is not None:
                break

        if send_result is None:
            logger.warning("Quick contact: send_v2 API call was not captured (timeout)")
            return False

        # Parse the API response
        response_text = send_result.get('response', '')
        try:
            resp_data = json.loads(response_text) if response_text else {}
        except (json.JSONDecodeError, TypeError):
            resp_data = {}

        ret = resp_data.get('ret')
        error_msg = resp_data.get('error', '')

        if ret == -1:
            logger.warning(f"Quick contact: send failed — {error_msg}")
            if error_msg:
                console.print(f"  [red]Quick Contact 失败: {error_msg}[/red]")
            return False

        logger.info("Quick contact: message sent successfully")
        await async_random_delay('action')

        # Display remaining quota
        if quota:
            _display_quota(quota, just_sent=True)

        return True

    except PermanentFailureError:
        raise  # Let quota exhaustion etc. propagate to abort the batch
    except Exception as e:
        logger.error(f"Quick contact handling failed: {e}\n{traceback.format_exc()}")
        return False


async def _detect_vip_paywall(page: Page) -> bool:
    """Detect if a VIP/membership paywall is blocking the current page.

    Non-VIP accounts may be redirected to a recharge/upgrade page when
    trying to message certain candidates. This checks the page URL and
    visible text for common paywall indicators.

    Args:
        page: Playwright page instance

    Returns:
        True if a VIP paywall is detected
    """
    try:
        return await page.evaluate('''() => {
            const url = window.location.href;
            const urlKeywords = ['vip', 'member', 'pay', 'recharge', 'upgrade', 'subscribe'];
            if (urlKeywords.some(kw => url.toLowerCase().includes(kw))) {
                return true;
            }

            const title = document.title || '';
            const bodyText = document.body ? document.body.innerText.substring(0, 3000) : '';
            const text = title + ' ' + bodyText;

            const paywallPatterns = [
                '开通会员', '升级会员', '会员专享', '会员权益',
                '充值', '付费', '购买会员', '开通VIP', '升级VIP',
                '立即开通', '立即升级', '立即购买',
                '会员到期', '续费', '解锁', '次数已用完',
                '今日沟通次数', '沟通人数已达上限',
            ];

            return paywallPatterns.some(p => text.includes(p));
        }''')
    except Exception as e:
        logger.debug(f"VIP paywall detection failed: {e}")
        return False


async def send_message(
    maimai_id: str,
    template_name: str,
    variables: Dict[str, str],
    browser: Optional[BrowserManager] = None,
    skip_confirmation: bool = False,
    interactive: bool = False,
    discovered_selectors: Optional['DiscoveredSelectors'] = None,
    _skip_rate_check: bool = False,
    profile_url: Optional[str] = None,
) -> bool:
    """
    Send a message to a candidate.

    Args:
        maimai_id: Candidate's Maimai ID
        template_name: Name of message template to use
        variables: Variables to substitute in template
        browser: Browser manager instance
        skip_confirmation: Skip confirmation (only for testing)
        interactive: Enable interactive selector discovery on failure
        discovered_selectors: Shared DiscoveredSelectors instance for reuse

    Returns:
        True if message was sent successfully

    Raises:
        RateLimitExceededError: If rate limit exceeded
        ValidationError: If template or variables invalid
    """
    # Validate and clean inputs
    maimai_id = validate_maimai_id(maimai_id)

    if browser is None:
        browser = get_browser_manager()

    config = get_config()
    rate_limiter = get_rate_limiter()
    db_manager = get_db_manager()

    # Get template
    try:
        template = config.get_template(template_name)
    except Exception as e:
        raise ValidationError(f"Template not found: {template_name}")

    # Validate template variables
    validate_template_variables(template, variables)

    # Render message content
    content = render_template(template['content'], variables)

    # Get candidate info for display
    candidate_info = _get_candidate_info(db_manager, maimai_id)

    # Preview and confirm
    if not skip_confirmation:
        action = await interactive_confirm(content, candidate_info, template_name)

        if action == 'skip':
            console.print("[yellow]Message skipped[/yellow]")
            _log_message(db_manager, maimai_id, template_name, content, 'cancelled')
            return False

        elif action == 'edit':
            # Allow user to edit content
            content = await edit_message(content)
            if content is None:
                console.print("[yellow]Message cancelled[/yellow]")
                return False

            # Re-confirm after edit
            action = await interactive_confirm(content, candidate_info, template_name)
            if action != 'send':
                console.print("[yellow]Message skipped[/yellow]")
                return False

        elif action != 'send':
            console.print("[yellow]Message cancelled[/yellow]")
            return False

    # Check rate limit (waits through min-interval) - skip when called from batch
    if not _skip_rate_check:
        await async_check_rate_limit('send_message')

    # Ensure logged in
    await ensure_logged_in(browser)

    try:
        page = browser.page

        # If we have populated discovered selectors, use them directly
        if discovered_selectors and discovered_selectors.is_populated:
            from src.modules.selector_discovery import apply_discovered_selectors
            success = await apply_discovered_selectors(
                page, maimai_id, discovered_selectors, content
            )
            if success:
                rate_limiter.log_action('send_message', {
                    'maimai_id': maimai_id,
                    'template': template_name
                })
                _log_message(db_manager, maimai_id, template_name, content, 'sent')
                console.print("[green]Message sent successfully![/green]")
                return True
            else:
                console.print("[red]Failed to send with discovered selectors[/red]")
                await browser.screenshot(f"message_error_{maimai_id}")
                _log_message(db_manager, maimai_id, template_name, content, 'failed')
                return False

        nav_ok = await _navigate_to_chat(
            page, profile_url, config, browser, maimai_id,
            interactive, discovered_selectors,
        )
        if not nav_ok:
            _log_message(db_manager, maimai_id, template_name, content, 'failed')
            return False

        # Check for "等待回应" (Awaiting Response) — already messaged this candidate
        try:
            awaiting = await page.evaluate('''() => {
                const text = document.body ? document.body.innerText : '';
                return text.includes('等待回应') || text.includes('等待对方回复');
            }''')
            if awaiting:
                logger.info(f"Candidate {maimai_id} already messaged (awaiting response), skipping")
                console.print(f"[yellow]Already messaged {maimai_id} (等待回应), skipping[/yellow]")
                _log_message(db_manager, maimai_id, template_name, content, 'cancelled')
                return False
        except Exception as e:
            logger.debug(f"Awaiting-response check failed for {maimai_id}: {e}")

        # Check for "极速联系" (Quick Contact) page
        qc_result = await _handle_quick_contact(page, content)
        if qc_result is True:
            rate_limiter.log_action('send_message', {
                'maimai_id': maimai_id,
                'template': template_name,
                'mode': 'quick_contact',
            })
            _log_message(db_manager, maimai_id, template_name, content, 'sent')
            console.print("[green]Message sent via Quick Contact![/green]")
            return True
        elif qc_result is False:
            console.print("[red]Quick Contact page detected but send failed[/red]")
            await browser.screenshot(f"message_error_qc_{maimai_id}")
            _log_message(db_manager, maimai_id, template_name, content, 'failed')
            return False
        # qc_result is None → not a quick contact page, continue normal flow

        # If interactive discovery succeeded, apply discovered selectors
        if discovered_selectors and discovered_selectors.is_populated:
            from src.modules.selector_discovery import apply_discovered_selectors
            success = await apply_discovered_selectors(
                page, maimai_id, discovered_selectors, content
            )
            if success:
                rate_limiter.log_action('send_message', {
                    'maimai_id': maimai_id,
                    'template': template_name
                })
                _log_message(db_manager, maimai_id, template_name, content, 'sent')
                console.print("[green]Message sent successfully![/green]")
                return True

        # Check for existing conversation to avoid duplicate greetings
        has_existing = await _check_existing_conversation(page, maimai_id)
        if has_existing:
            console.print(f"[yellow]Existing conversation detected with {maimai_id}. Skipping to avoid duplicate.[/yellow]")
            _log_message(db_manager, maimai_id, template_name, content, 'cancelled')
            return False

        # Find message input and type message
        input_found = await _type_message(page, config, content)
        if not input_found:
            console.print("[red]Could not find message input[/red]")
            await browser.screenshot(f"message_error_{maimai_id}")
            _log_message(db_manager, maimai_id, template_name, content, 'failed')
            return False

        await async_random_delay('action')

        # Click send button
        sent = await _click_send_button(page, config)
        if not sent:
            console.print("[red]Could not send message[/red]")
            await browser.screenshot(f"message_error_{maimai_id}")
            _log_message(db_manager, maimai_id, template_name, content, 'failed')
            return False

        # Check if clicking send triggered a VIP paywall popup
        await asyncio.sleep(1)
        if await _detect_vip_paywall(page):
            console.print(f"[yellow]VIP paywall popup appeared after send for {maimai_id}, skipping[/yellow]")
            _log_message(db_manager, maimai_id, template_name, content, 'cancelled')
            raise PermanentFailureError(f"VIP paywall detected for {maimai_id}")

        # Verify message was actually sent
        verified = await _verify_message_sent(page, content)
        if not verified:
            logger.warning(f"Message to {maimai_id}: send button clicked but could not verify delivery")
            console.print("[yellow]Warning: Message send could not be verified. Marking as unverified.[/yellow]")
            await browser.screenshot(f"message_unverified_{maimai_id}")
            # Still log as sent but with unverified note in details
            rate_limiter.log_action('send_message', {
                'maimai_id': maimai_id,
                'template': template_name,
                'verified': False,
            })
            _log_message(db_manager, maimai_id, template_name, content, 'sent')
            console.print("[yellow]Message marked as sent (unverified)[/yellow]")
            return True

        # Log action
        rate_limiter.log_action('send_message', {
            'maimai_id': maimai_id,
            'template': template_name,
            'verified': True,
        })

        # Log message to database
        _log_message(db_manager, maimai_id, template_name, content, 'sent')

        console.print("[green]Message sent and verified![/green]")
        return True

    except PermanentFailureError:
        raise
    except Exception as e:
        logger.error(f"Error sending message: {e}")
        await browser.screenshot(f"message_error_{maimai_id}")
        _log_message(db_manager, maimai_id, template_name, content, 'failed')
        raise


async def send_message_batch(
    candidates: List[dict],
    template_name: str,
    common_variables: Dict[str, str],
    browser: BrowserManager,
    skip_messaged: bool = True,
    interactive: bool = False,
    skip_confirmation: bool = False,
) -> Dict[str, Any]:
    """
    Batch send messages to a list of candidates.

    Flow:
    1. Filter already-messaged candidates
    2. Auto-fill name/company/position variables per candidate
    3. Render message template
    4. Show candidate list + first message preview
    5. Single confirmation
    6. Send one by one, checking rate limit each time
    7. Skip failures and record
    8. Return result stats

    Args:
        candidates: List of dicts with maimai_id, name, company, title
        template_name: Name of message template
        common_variables: Shared variables (recruiter_name, target_position, etc.)
        browser: Browser manager instance
        skip_messaged: Skip candidates already messaged (default True)
        interactive: Enable interactive selector discovery on first failure

    Returns:
        Dict with total, sent, failed, skipped, rate_limited, details
    """
    config = get_config()
    rate_limiter = get_rate_limiter()
    db_manager = get_db_manager()

    # Get template
    try:
        template = config.get_template(template_name)
    except Exception:
        raise ValidationError(f"Template not found: {template_name}")

    # Create shared discovered selectors for interactive mode
    if interactive:
        from src.modules.selector_discovery import DiscoveredSelectors
        discovered_selectors = DiscoveredSelectors()
    else:
        discovered_selectors = None

    results = {
        'total': len(candidates),
        'sent': 0,
        'failed': 0,
        'skipped': 0,
        'rate_limited': 0,
        'details': [],
    }

    # Filter already-messaged candidates
    send_list = []
    if skip_messaged:
        # Batch pre-fetch all sent message IDs to avoid N+1 queries
        all_ids = [c['maimai_id'] for c in candidates]
        messaged_ids = set()
        with db_manager.session_scope() as session:
            rows = session.query(Message.candidate_maimai_id).filter(
                Message.candidate_maimai_id.in_(all_ids),
                Message.status == 'sent'
            ).distinct().all()
            messaged_ids = {row[0] for row in rows}

        for c in candidates:
            if c['maimai_id'] in messaged_ids:
                results['skipped'] += 1
                results['details'].append({
                    'maimai_id': c['maimai_id'],
                    'name': c['name'],
                    'status': 'skipped',
                    'reason': 'already messaged',
                })
            else:
                send_list.append(c)
    else:
        send_list = list(candidates)

    if not send_list:
        console.print("[yellow]No candidates to send messages to.[/yellow]")
        return results

    # Pre-validate all candidates can render template (防止发送到一半才发现变量缺失)
    console.print("[dim]Validating template for all candidates...[/dim]")
    for c in send_list:
        test_vars = {
            **common_variables,
            'name': c.get('name', ''),
            'company': c.get('company', ''),
            'position': c.get('title', ''),
        }
        is_valid, missing = validate_template_rendering(template['content'], test_vars, c)
        if not is_valid:
            raise ValidationError(
                f"候选人 {c.get('name', 'Unknown')} 的模板变量缺失或为空:\n"
                f"  缺失: {', '.join(missing)}\n"
                f"  候选人信息: {c}\n"
                f"  请检查模板或补充变量"
            )

    # Build preview for first candidate
    first = send_list[0]
    first_vars = {**common_variables, 'name': first['name'], 'company': first['company'], 'position': first['title']}
    first_content = render_template(template['content'], first_vars, validate=False)  # Already validated above

    # Display summary panel
    summary_text = Text()
    summary_text.append("Template: ", style="bold")
    summary_text.append(f"{template_name}\n")
    summary_text.append("Candidates: ", style="bold")
    summary_text.append(f"{len(candidates)} found, {results['skipped']} already messaged\n")
    summary_text.append("Will send to: ", style="bold")
    summary_text.append(f"{len(send_list)} candidates\n\n")
    summary_text.append("Message Preview ", style="bold cyan")
    summary_text.append(f"(first candidate):\n", style="dim")
    summary_text.append("To: ", style="bold cyan")
    recipient = first['name']
    if first.get('title') and first.get('company'):
        recipient += f" ({first['title']} @ {first['company']})"
    summary_text.append(f"{recipient}\n\n")
    summary_text.append(first_content)

    console.print(Panel(
        summary_text,
        title="Pipeline Summary",
        border_style="green",
        padding=(1, 2)
    ))

    # Single confirmation (skip if --yes flag or non-interactive environment)
    if skip_confirmation:
        console.print(f"[green]Auto-confirmed: sending to {len(send_list)} candidates[/green]")
    else:
        loop = asyncio.get_running_loop()
        confirm = await loop.run_in_executor(
            None,
            lambda: questionary.confirm(
                f"Confirm batch send to {len(send_list)} candidates?"
            ).unsafe_ask()
        )

        if not confirm:
            console.print("[yellow]Batch send cancelled.[/yellow]")
            return results

    # Send messages one by one
    from rich.progress import Progress, BarColumn, TextColumn as ProgressTextColumn, MofNCompleteColumn

    with Progress(
        ProgressTextColumn("[progress.description]{task.description}"),
        BarColumn(),
        MofNCompleteColumn(),
        console=console
    ) as progress:
        task = progress.add_task("Sending messages...", total=len(send_list))

        max_retries = 2
        rate_limit_hit = False

        for c in send_list:
            if rate_limit_hit:
                break

            # Check rate limit (waits through min-interval)
            try:
                await async_check_rate_limit('send_message')
            except RateLimitExceededError as e:
                console.print(f"\n[yellow]Rate limit reached: {e}[/yellow]")
                remaining = len(send_list) - (results['sent'] + results['failed'])
                results['rate_limited'] = remaining
                results['details'].append({
                    'maimai_id': c['maimai_id'],
                    'name': c['name'],
                    'status': 'rate_limited',
                    'reason': str(e),
                })
                break

            # Build per-candidate variables
            variables = {
                **common_variables,
                'name': c['name'],
                'company': c['company'],
                'position': c['title'],
            }
            try:
                content = render_template(template['content'], variables, validate=False)  # Already validated in batch
            except ValidationError as e:
                # Should not happen if pre-validation passed, but handle gracefully
                logger.error(f"Template rendering failed for {c['name']}: {e}")
                results['failed'] += 1
                results['details'].append({
                    'maimai_id': c['maimai_id'],
                    'name': c['name'],
                    'status': 'failed',
                    'reason': f"模板渲染失败: {e}",
                })
                continue

            # Retry loop for transient failures
            sent = False
            last_error = None
            per_candidate_timeout = 90  # seconds per candidate
            for attempt in range(1 + max_retries):
                try:
                    success = await asyncio.wait_for(
                        send_message(
                            maimai_id=c['maimai_id'],
                            template_name=template_name,
                            variables=variables,
                            browser=browser,
                            skip_confirmation=True,
                            interactive=interactive,
                            discovered_selectors=discovered_selectors,
                            _skip_rate_check=True,
                            profile_url=c.get('profile_url'),
                        ),
                        timeout=per_candidate_timeout,
                    )

                    if success:
                        results['sent'] += 1
                        results['details'].append({
                            'maimai_id': c['maimai_id'],
                            'name': c['name'],
                            'status': 'sent',
                            'attempts': attempt + 1,
                            'content': content,
                        })
                        sent = True
                        break
                    else:
                        last_error = "send returned False"

                except asyncio.TimeoutError:
                    last_error = f"Timed out after {per_candidate_timeout}s"
                    console.print(f"[yellow]Timeout for {c['name']} ({c['maimai_id']}), skipping.[/yellow]")
                    break
                except QuotaExhaustedError as e:
                    # Quota is a global resource — abort the entire batch
                    remaining = len(send_list) - (results['sent'] + results['failed'])
                    results['failed'] += 1
                    results['details'].append({
                        'maimai_id': c['maimai_id'],
                        'name': c['name'],
                        'status': 'quota_exhausted',
                        'reason': str(e),
                    })
                    console.print(f"\n[red]联系券已用尽，终止批量发送 (剩余 {remaining - 1} 人未发送)[/red]")
                    rate_limit_hit = True  # reuse flag to skip remaining candidates
                    break
                except PermanentFailureError as e:
                    last_error = str(e)
                    console.print(f"[yellow]{e}. Skipping.[/yellow]")
                    break
                except RateLimitExceededError as e:
                    remaining = len(send_list) - (results['sent'] + results['failed'])
                    results['rate_limited'] = remaining
                    results['details'].append({
                        'maimai_id': c['maimai_id'],
                        'name': c['name'],
                        'status': 'rate_limited',
                        'reason': str(e),
                    })
                    console.print(f"\n[yellow]Rate limit reached: {e}[/yellow]")
                    rate_limit_hit = True
                    break
                except Exception as e:
                    last_error = str(e)

                # Retry with exponential backoff if not last attempt
                if attempt < max_retries and not rate_limit_hit:
                    from src.utils.delays import get_retry_delay
                    delay = get_retry_delay(attempt, base_delay=3.0, max_delay=30.0)
                    logger.info(f"Retry {attempt + 1}/{max_retries} for {c['name']} in {delay:.1f}s")
                    await asyncio.sleep(delay)

            if not sent and not rate_limit_hit:
                actual_attempts = attempt + 1
                results['failed'] += 1
                results['details'].append({
                    'maimai_id': c['maimai_id'],
                    'name': c['name'],
                    'status': 'failed',
                    'reason': last_error,
                    'attempts': actual_attempts,
                    'content': content,
                })
                logger.error(f"Failed to send message to {c['name']} after {actual_attempts} attempt(s): {last_error}")

            progress.advance(task)

            # Emit progress for web service
            emit_progress("send_progress",
                          sent=results['sent'], failed=results['failed'],
                          total=len(send_list), current=c['name'])

            # Human-like delay between messages
            await async_random_delay('message')

    return results


def render_template(template_content: str, variables: Dict[str, str], validate: bool = True) -> str:
    """
    Render template with variables.

    Maimai chat is plain text, so values are substituted as-is without
    HTML escaping (which would produce visible &amp; entities in chat).

    Args:
        template_content: Template string with {variable} placeholders
        variables: Variable values to substitute
        validate: Whether to validate template before rendering (default True)

    Returns:
        Rendered message content

    Raises:
        ValidationError: If template validation fails and validate=True
    """
    if validate:
        # Validate template can be fully rendered
        is_valid, missing = validate_template_rendering(template_content, variables, {})
        if not is_valid:
            raise ValidationError(
                f"模板变量缺失或为空: {', '.join(missing)}\n"
                f"请检查模板或提供完整变量"
            )

    content = template_content
    for key, value in variables.items():
        content = content.replace(f"{{{key}}}", str(value))
    return content


def preview_message(
    template_name: str,
    variables: Dict[str, str],
    candidate_info: Optional[Dict] = None
) -> str:
    """
    Preview a message without sending.

    Args:
